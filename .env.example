# Environment Configuration
# Copy this file to .env.local and update with your values

# ======================
# DATABASE
# ======================
# MongoDB (Recommended)
MONGODB_URI=mongodb://localhost:27017/sweet-platform
# MongoDB Atlas (Production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sweet-platform?retryWrites=true&w=majority

# ======================
# AUTHENTICATION & SECURITY
# ======================
# JWT Secret (REQUIRED - Generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# CSRF Secret (REQUIRED - Generate a secure random string)
CSRF_SECRET=your-super-secret-csrf-key-change-this-in-production-min-32-chars

# Default Admin Password (will be hashed automatically)
ADMIN_DEFAULT_PASSWORD=admin123

# Session Configuration
SESSION_MAX_AGE=604800
# 604800 = 7 days in seconds

# ======================
# FILE UPLOAD - CLOUDINARY
# ======================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ======================
# EMAIL SERVICE (Optional - for contact form notifications)
# ======================
# Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# SendGrid (Alternative)
# SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES (Alternative)
# AWS_SES_ACCESS_KEY_ID=your-access-key
# AWS_SES_SECRET_ACCESS_KEY=your-secret-key
# AWS_SES_REGION=us-east-1

# ======================
# APPLICATION
# ======================
NODE_ENV=development
# Change to 'production' when deploying

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://yourdomain.com

# ======================
# RATE LIMITING
# ======================
# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# ======================
# OPTIONAL SERVICES
# ======================
# Google Maps API (for branch locations)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ======================
# SECURITY HEADERS
# ======================
# Content Security Policy
CSP_ENABLED=true

# ======================
# NOTES
# ======================
# 1. Never commit .env.local to version control
# 2. Generate strong random secrets for JWT_SECRET and CSRF_SECRET
# 3. Use environment-specific values for production
# 4. Enable HTTPS in production (handled by hosting platform)
# 5. Set NODE_ENV=production in production environment
